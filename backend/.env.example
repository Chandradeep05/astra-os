# ASTRA OS — Environment Configuration Template
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

PROJECT_NAME="ASTRA OS"
ENV=development

# 🧠 BRAIN CONFIGURATION (Ollama — 100% Local)
OLLAMA_BASE_URL="http://localhost:11434"
DEFAULT_MODEL="llama3.2:1b"

# 🗄️ DATABASE
DATABASE_URL="sqlite:///./astra_os.db"

# 🔍 TOOLS CONFIGURATION
# Get your free key at https://serper.dev
SERPER_API_KEY=""

# 🛡️ SECURITY
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000"
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"

# SYSTEM
LOG_LEVEL="INFO"
PORT=8000
